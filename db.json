{
    "config": {
        "site": {
            "name": "ویترین",
            "description": "فروشگاه آزمایشی ویترین",
            "icon": "https://vitrin-store.ir/shop-resources/cKvifROQYh/shop-logos/1732178597_16936.png",
            "logo": "https://vitrin-store.ir/shop-resources/cKvifROQYh/shop-logos/1732178597_16936.png"
        },
        "layout": {
            "hasMegaMenu": true,
            "productListView": "grid",
            "productCardFields": [
                "brand",
                "rating",
                "price",
                "discount",
                "stock"
            ]
        },
        "redirects": [
            {
                "source": "/about-us",
                "destination": "/about",
                "permanent": true
            },
            {
                "source": "/old-shop",
                "destination": "/products",
                "permanent": false
            }
        ],
        "sitemap": {
            "enabled": true,
            "includeStaticRoutes": true,
            "includeProducts": true,
            "entries": [
                {
                    "path": "/about",
                    "changeFrequency": "monthly",
                    "priority": 0.6
                }
            ],
            "exclude": []
        },
        "robots": {
            "rules": [
                {
                    "userAgent": "*",
                    "allow": "/",
                    "disallow": ["/api", "/signin", "/signup", "/panel"]
                }
            ]
        },
        "maintenance": {
            "enabled": true,
            "scope": "pages",
            "pages": [
                {
                    "path": "/about",
                    "mode": "offHours",
                    "message": "صفحه درباره ما در حال حاضر خارج از ساعت کاری است.",
                    "workingHours": "شنبه تا چهارشنبه، ۰۹:۰۰ تا ۱۷:۰۰"
                },
                {
                    "path": "/cart",
                    "mode": "maintenance",
                    "message": "سبد خرید موقتاً در حال تعمیر است."
                }
            ],
            "message": "این بخش موقتاً در دسترس نیست."
        },
        "theme": {
            "light": {
                "background": "#f8fafc",
                "foreground": "#0f172a",
                "card": "#ffffff",
                "cardForeground": "#0f172a",
                "popover": "#ffffff",
                "popoverForeground": "#0f172a",
                "primary": "#2563eb",
                "primaryForeground": "#ffffff",
                "secondary": "#e2e8f0",
                "secondaryForeground": "#334155",
                "muted": "#f1f5f9",
                "mutedForeground": "#64748b",
                "accent": "#f97316",
                "accentForeground": "#ffffff",
                "destructive": "#dc2626",
                "border": "#e2e8f0",
                "input": "#e2e8f0",
                "ring": "#2563eb",
                "chart1": "#2563eb",
                "chart2": "#f97316",
                "chart3": "#16a34a",
                "chart4": "#9333ea",
                "chart5": "#dc2626",
                "sidebar": "#ffffff",
